{
  "manifest_version": 3,
  "name": "Save Picture As",
  "version": "1.2.0",
  "description": "Right-click any picture to save it as PNG, JPEG, or WebP.",
  "permissions": [
    "contextMenus",
    "downloads",
    "offscreen",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
